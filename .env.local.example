# Charles Schwab API credentials
# 1. Go to https://developer.schwab.com/dashboard/apps
# 2. Create a new app (or use existing), set callback URL to https://127.0.0.1
# 3. Copy Client ID and Client Secret below
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=https://127.0.0.1

# X / Twitter API (optional — enables Voices panel real-time tweets)
# Get from https://developer.twitter.com/en/portal/dashboard
X_BEARER_TOKEN=
